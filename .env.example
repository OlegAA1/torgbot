# Скопировать в .env и заполнить ключами ДЕМО-среды Bybit
# (Profile -> Demo Trading -> API -> Create New Key, права: только Read + Trade)
API_KEY=
API_SECRET=

# Telegram-уведомления (необязательно; пусто = выключены)
# Токен выдаёт @BotFather; chat_id можно узнать у @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
